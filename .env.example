# ============================================================
# RadiusManager API — Environment Configuration
# Salin file ini ke .env dan sesuaikan nilainya.
# ============================================================

# ── API Security ────────────────────────────────────────────
# WAJIB diganti di production!  Generate: openssl rand -hex 32
API_KEY=GANTI_DENGAN_SECRET_PANJANG_32_KARAKTER_MINIMAL

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

API_TITLE=RadiusManager API
API_VERSION=1.0.0

# ── FreeRADIUS ───────────────────────────────────────────────
FREERADIUS_DIR=/etc/freeradius/3.0
FR_USER=freerad
FR_GROUP=freerad
FR_SCHEMA=/etc/freeradius/3.0/mods-config/sql/main/mysql/schema.sql
RADIUS_MANAGER_SCRIPT=./radius-manager.sh

# ── MariaDB / MySQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=53360
DB_SOCKET=/var/run/mysqld/mysqld.sock
DB_ROOT_USER=root
DB_ROOT_PASSWORD=
DB_REMOTE_HOST=%
ALLOW_REMOTE_DB=true

# ── Port Auto-Assign ─────────────────────────────────────────
PORT_AUTH_START=11000
PORT_AUTH_STEP=10
